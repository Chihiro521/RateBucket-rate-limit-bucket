{
  "manifest_version": 3,
  "name": "AI 用量浮窗",
  "version": "0.1.0",
  "description": "用于 Grok、Claude 和 ChatGPT 的浮动用量监控器。",
  "permissions": ["storage", "scripting"],
  "host_permissions": [
    "https://grok.com/*",
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://proxycheck.io/*",
    "https://api64.ipify.org/*"
  ],
  "background": {
    "service_worker": "serviceWorker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://grok.com/*",
        "https://claude.ai/*",
        "https://chatgpt.com/*"
      ],
      "js": ["mainWorldBridge.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": [
        "https://grok.com/*",
        "https://claude.ai/*",
        "https://chatgpt.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
