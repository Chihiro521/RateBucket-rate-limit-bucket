{
  "manifest_version": 3,
  "name": "AI Usage Floating Monitor",
  "version": "0.1.0",
  "description": "Floating usage monitor for Grok, Claude, and ChatGPT.",
  "permissions": ["storage", "scripting"],
  "host_permissions": [
    "https://grok.com/*",
    "https://claude.ai/*",
    "https://chatgpt.com/*"
  ],
  "background": {
    "service_worker": "serviceWorker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://grok.com/*",
        "https://claude.ai/*",
        "https://chatgpt.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
